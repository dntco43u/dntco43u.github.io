&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#ebcb8b"&gt;&lt;/span&gt;sudo nmcli connection up &lt;span style="color:#a3be8c"&gt;&amp;#34;ens18&amp;#34;&lt;/span&gt;
